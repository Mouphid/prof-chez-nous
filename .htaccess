# Bloquer l'accès aux dossiers sensibles
RedirectMatch 403 ^/(config|includes|sql|vendor|logs)/.*$

# Protéger les fichiers sensibles à la racine
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "^(composer\.(json|lock)|skills-lock\.json|README\.md)$">
    Require all denied
</FilesMatch>

# Désactiver le listing des répertoires
Options -Indexes

# Headers de sécurité
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Bloquer l'exécution PHP dans uploads
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/.*\.(php|phtml|php3|php4|php5|phps)$ - [F,L]
</IfModule>

# Empêcher l'accès au dossier _debug_backup
RedirectMatch 403 ^/_debug_backup/.*$
